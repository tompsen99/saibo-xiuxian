// ===== ACHIEVEMENT SYSTEM (成就系统) =====
const ACHIEVEMENTS = {
  // 战斗成就
  first_kill: { name: '初出茅庐', desc: '首次击杀怪物', icon: '⚔️', check: p => (p.totalKills || 0) >= 1 },
  kill_100: { name: '百战老兵', desc: '击杀100只怪物', icon: '🗡️', check: p => (p.totalKills || 0) >= 100 },
  kill_1000: { name: '千人斩', desc: '击杀1000只怪物', icon: '💀', check: p => (p.totalKills || 0) >= 1000 },
  // 修炼成就
  realm_3: { name: '初窥门径', desc: '达到灵动境', icon: '🌀', check: p => (p.realmLevel || 0) >= 3 },
  realm_6: { name: '登堂入室', desc: '达到金丹境', icon: '💎', check: p => (p.realmLevel || 0) >= 6 },
  realm_9: { name: '超凡入圣', desc: '达到渡劫境', icon: '⚡', check: p => (p.realmLevel || 0) >= 9 },
  realm_12: { name: '破碎虚空', desc: '达到最高境界', icon: '🌌', check: p => (p.realmLevel || 0) >= 12 },
  // 收集成就
  relic_12: { name: '遗物收藏家', desc: '收集12件遗物', icon: '📦', check: p => (p.relics || []).length >= 12 },
  relic_36: { name: '遗物大师', desc: '集齐36件遗物', icon: '🏆', check: p => (p.relics || []).length >= 36 },
  bug_10: { name: 'Bug猎人', desc: '发现10种Bug', icon: '🐛', check: p => (p.discoveredBugs || []).length >= 10 },
  bug_32: { name: 'Bug终结者', desc: '发现全部32种Bug', icon: '🔧', check: p => (p.discoveredBugs || []).length >= 32 },
  // 社交成就
  friend_5: { name: '广结善缘', desc: '拥有5个好友', icon: '🤝', check: p => (p.friends || []).length >= 5 },
  sect_master: { name: '一派之主', desc: '成为门派掌门', icon: '👑', check: p => p.sectPosition === '掌门' },
  // 财富成就
  silver_10k: { name: '小有资产', desc: '拥有10000灵石', icon: '💰', check: p => (p.silver || 0) >= 10000 },
  silver_100k: { name: '富甲一方', desc: '拥有100000灵石', icon: '💎', check: p => (p.silver || 0) >= 100000 },
  // 特殊成就
  vip_achieve: { name: '尊贵会员', desc: '激活VIP', icon: '🌟', check: p => isVipActive(p) },
  watch_lv9: { name: '创世者', desc: '手表达到Lv9', icon: '⌚', check: p => (p.adminWatchLevel || 0) >= 9 },
  puzzle_solve: { name: '谜题大师', desc: '完成遗物解谜', icon: '🧩', check: p => p.puzzleSolved || false },
  ending_achieve: { name: '命运之子', desc: '达成真结局', icon: '🎊', check: p => !!p.endingChoice },
  dao_1000: { name: '道心圆满', desc: '道心达到1000', icon: '❤️', check: p => (p.daoHeart || 500) >= 1000 },
  sign_30: { name: '坚持不懈', desc: '连续签到30天', icon: '📅', check: p => (p.signConsecutive || 0) >= 30 },
};

function checkAchievements(player) {
  const newAchievements = [];
  if (!player.achievements) player.achievements = [];
  for (const [id, ach] of Object.entries(ACHIEVEMENTS)) {
    if (!player.achievements.includes(id) && ach.check(player)) {
      player.achievements.push(id);
      newAchievements.push(ach);
    }
  }
  return newAchievements;
}

function handleAchievementCommand(ws, player) {
  const players = getPlayers();
  const p = players[player.id];
  const newAch = checkAchievements(p);
  if (newAch.length > 0) savePlayers(players);
  
  const unlocked = p.achievements || [];
  let content = '\n╔══════════════════════════════════╗\n║  成就系统\n╠══════════════════════════════════╣\n';
  content += `║  已解锁: ${unlocked.length}/${Object.keys(ACHIEVEMENTS).length}\n╠══════════════════════════════════╣\n`;
  for (const [id, ach] of Object.entries(ACHIEVEMENTS)) {
    const done = unlocked.includes(id);
    content += `║  ${done ? ach.icon : '🔒'} ${ach.name}: ${ach.desc} ${done ? '✅' : ''}\n`;
  }
  content += '╚══════════════════════════════════╝';
  
  sendToClient(ws, { type: 'command_response', data: { title: '成就系统', content } });
  
  if (newAch.length > 0) {
    const names = newAch.map(a => `${a.icon} ${a.name}`).join(', ');
    sendToClient(ws, { type: 'system', data: { message: `🎉 新成就解锁: ${names}` } });
  }
}

// ===== LEADERBOARD SYSTEM (排行榜) =====
function handleLeaderboardCommand(ws, player) {
  const players = getPlayers();
  const sorted = Object.values(players).sort((a, b) => (b.level || 1) - (a.level || 1));
  const top10 = sorted.slice(0, 10);
  
  let content = '\n╔══════════════════════════════════╗\n║  排行榜 (Top 10)\n╠══════════════════════════════════╣\n';
  top10.forEach((p, i) => {
    const medal = i === 0 ? '🥇' : i === 1 ? '🥈' : i === 2 ? '🥉' : `${i+1}.`;
    content += `║  ${medal} ${p.name} Lv${p.level} ${p.realm || ''}\n`;
  });
  
  const playerRank = sorted.findIndex(p => p.id === player.id) + 1;
  content += `╠══════════════════════════════════╣\n║  你的排名: #${playerRank}\n╚══════════════════════════════════╝`;
  
  sendToClient(ws, { type: 'command_response', data: { title: '排行榜', content } });
}

// ===== BOSS SYSTEM (BOSS战) =====
const WORLD_BOSSES = [
  { id: 'boss_1', name: '千年树妖', level: 20, hp: 5000, attack: 80, defense: 40, exp: 2000, silver: 500, drop: '妖兽内丹', dropRate: 0.3, realm: '竹林深处' },
  { id: 'boss_2', name: '冰霜巨龙', level: 40, hp: 15000, attack: 200, defense: 100, exp: 8000, silver: 2000, drop: '龙鳞碎片', dropRate: 0.2, realm: '雪山之巅' },
  { id: 'boss_3', name: '天劫雷兽', level: 60, hp: 50000, attack: 500, defense: 200, exp: 30000, silver: 8000, drop: '雷劫精华', dropRate: 0.15, realm: '天劫荒原' },
  { id: 'boss_4', name: '源码守护者', level: 80, hp: 100000, attack: 1000, defense: 500, exp: 100000, silver: 30000, drop: '源码碎片', dropRate: 0.1, realm: '源码之心' },
  { id: 'boss_5', name: '虚空主宰', level: 100, hp: 500000, attack: 3000, defense: 1500, exp: 500000, silver: 100000, drop: '虚空核心', dropRate: 0.05, realm: '虚空裂缝' },
];

function handleBossCommand(ws, player, command) {
  const arg = command.replace('/BOSS', '').trim();
  if (!arg) {
    let content = '\n╔══════════════════════════════════╗\n║  世界BOSS\n╠══════════════════════════════════╣\n';
    for (const boss of WORLD_BOSSES) {
      const killed = (player.bossKills || {})[boss.id] || 0;
      content += `║  ${boss.name} Lv${boss.level}\n║    位置: ${boss.realm} | 击杀: ${killed}次\n║    奖励: ${boss.exp}经验, ${boss.silver}灵石\n║    掉落: ${boss.drop}(${Math.floor(boss.dropRate*100)}%)\n║\n`;
    }
    content += '║  /BOSS 挑战 <BOSS名> - 挑战BOSS\n╚══════════════════════════════════╝';
    sendToClient(ws, { type: 'command_response', data: { title: '世界BOSS', content } });
    return;
  }
  
  if (arg.startsWith('挑战')) {
    const bossName = arg.replace('挑战', '').trim();
    const boss = WORLD_BOSSES.find(b => b.name === bossName);
    if (!boss) { sendToClient(ws, { type: 'system', data: { message: '未找到该BOSS。' } }); return; }
    if ((player.level || 1) < boss.level - 10) {
      sendToClient(ws, { type: 'system', data: { message: `你的等级不足！需要至少Lv${boss.level - 10}才能挑战${boss.name}。` } });
      return;
    }
    // Simple boss combat
    const players = getPlayers();
    const p = players[player.id];
    let playerHp = p.hp || p.maxHp || 100;
    let bossHp = boss.hp;
    let rounds = 0;
    const log = [];
    while (playerHp > 0 && bossHp > 0 && rounds < 50) {
      rounds++;
      const pAtk = Math.max(1, (p.attack || 50) - boss.defense + Math.floor(Math.random() * 20));
      bossHp -= pAtk;
      log.push(`第${rounds}回合: 你攻击${boss.name}造成${pAtk}伤害 (BOSS HP: ${Math.max(0, bossHp)})`);
      if (bossHp <= 0) break;
      const bAtk = Math.max(1, boss.attack - (p.defense || 20) + Math.floor(Math.random() * 20));
      playerHp -= bAtk;
      log.push(`第${rounds}回合: ${boss.name}攻击你造成${bAtk}伤害 (你的HP: ${Math.max(0, playerHp)})`);
    }
    
    if (bossHp <= 0) {
      // Victory
      p.exp = (p.exp || 0) + boss.exp;
      p.silver = (p.silver || 0) + boss.silver;
      if (!p.bossKills) p.bossKills = {};
      p.bossKills[boss.id] = (p.bossKills[boss.id] || 0) + 1;
      let dropMsg = '';
      if (Math.random() < boss.dropRate) {
        if (!p.materials) p.materials = {};
        p.materials[boss.drop] = (p.materials[boss.drop] || 0) + 1;
        dropMsg = `\n║  获得掉落: ${boss.drop}`;
      }
      savePlayers(players);
      log.push(`\n🎉 你击败了${boss.name}！\n║  获得: ${boss.exp}经验, ${boss.silver}灵石${dropMsg}`);
    } else {
      p.hp = Math.floor((p.maxHp || 100) * 0.3);
      savePlayers(players);
      log.push(`\n💀 你被${boss.name}击败了！HP恢复到30%。`);
    }
    
    sendToClient(ws, { type: 'command_response', data: { title: `BOSS战: ${boss.name}`, content: log.join('\n') } });
    return;
  }
}

// ===== MAIN QUEST SYSTEM (剧情主线) =====
const MAIN_QUESTS = [
  { id: 'mq_1', name: '第一章：初入江湖', desc: '完成新手引导，达到灵动境', condition: p => (p.realmLevel || 0) >= 3, reward: { exp: 500, silver: 200 } },
  { id: 'mq_2', name: '第二章：拜师学艺', desc: '加入门派，学习3个功法', condition: p => p.sect && (p.skills || []).length >= 3, reward: { exp: 1000, silver: 500 } },
  { id: 'mq_3', name: '第三章：历练江湖', desc: '击杀100只怪物，收集5件遗物', condition: p => (p.totalKills || 0) >= 100 && (p.relics || []).length >= 5, reward: { exp: 2000, silver: 1000 } },
  { id: 'mq_4', name: '第四章：门派纷争', desc: '成为门派长老，道心达到700', condition: p => ['长老', '掌门'].includes(p.sectPosition) && (p.daoHeart || 500) >= 700, reward: { exp: 5000, silver: 3000 } },
  { id: 'mq_5', name: '第五章：天劫降临', desc: '达到渡劫境，修复10种Bug', condition: p => (p.realmLevel || 0) >= 9 && (p.fixedBugs || []).length >= 10, reward: { exp: 10000, silver: 5000 } },
  { id: 'mq_6', name: '第六章：源码之心', desc: '达到最高境界，集齐36遗物', condition: p => (p.realmLevel || 0) >= 12 && (p.relics || []).length >= 36, reward: { exp: 50000, silver: 20000 }, final: true },
];

function handleMainQuestCommand(ws, player, command) {
  const arg = command.replace('/主线', '').trim();
  const players = getPlayers();
  const p = players[player.id];
  if (!p.mainQuestProgress) p.mainQuestProgress = 0;
  
  if (!arg || arg === '查看') {
    let content = '\n╔══════════════════════════════════╗\n║  剧情主线\n╠══════════════════════════════════╣\n';
    for (let i = 0; i < MAIN_QUESTS.length; i++) {
      const q = MAIN_QUESTS[i];
      const status = i < p.mainQuestProgress ? '✅ 已完成' : i === p.mainQuestProgress ? '📌 进行中' : '🔒 未解锁';
      content += `║  ${status} ${q.name}\n║    ${q.desc}\n║\n`;
    }
    content += `║  进度: ${p.mainQuestProgress}/${MAIN_QUESTS.length}\n╚══════════════════════════════════╝`;
    sendToClient(ws, { type: 'command_response', data: { title: '剧情主线', content } });
    return;
  }
  
  if (arg === '提交') {
    const current = MAIN_QUESTS[p.mainQuestProgress];
    if (!current) { sendToClient(ws, { type: 'system', data: { message: '所有主线任务已完成！' } }); return; }
    if (!current.condition(p)) { sendToClient(ws, { type: 'system', data: { message: `未完成条件: ${current.desc}` } }); return; }
    p.exp = (p.exp || 0) + current.reward.exp;
    p.silver = (p.silver || 0) + current.reward.silver;
    p.mainQuestProgress++;
    if (current.final) p.mainQuestComplete = true;
    savePlayers(players);
    sendToClient(ws, { type: 'system', data: { message: `🎉 完成【${current.name}】！\n获得: ${current.reward.exp}经验, ${current.reward.silver}灵石${current.final ? '\n🎊 主线剧情完结！' : ''}` } });
    return;
  }
}

// ===== NPC DIALOG SYSTEM (NPC对话) =====
const NPC_DIALOGS = {
  '村长': {
    greeting: '年轻人，欢迎来到赛博修仙的世界。这里的一切都是代码构成的。',
    topics: {
      '修仙': '修仙之路漫漫，需要不断修炼功法、提升境界。记住，道心是根本。',
      '遗物': '程序遗物是上古程序员留下的神器，集齐它们可以获得强大的力量。',
      'Bug': 'Bug是这个世界的漏洞，利用它们可以获得优势，但要小心被管理员发现。',
      '手表': '管理员手表是创世者的遗物，提升它的等级可以解锁更多功能。'
    }
  },
  '药铺老板': {
    greeting: '客官，需要什么丹药？本店货真价实！',
    topics: {
      '丹药': '丹药分回复、增益、特殊三类。战斗前准备好丹药很重要。',
      '炼丹': '想要自己炼丹？需要炼丹炉和材料。材料可以从怪物掉落或采集获得。',
      '材料': '灵草在竹林可以找到，妖兽内丹需要击杀BOSS获得。'
    }
  },
  '铁匠': {
    greeting: '要打造装备吗？给我材料就行！',
    topics: {
      '装备': '装备分武器、护甲、饰品三类，可以强化提升属性。',
      '强化': '装备强化需要强化石，强化等级越高，属性越强。',
      '锻造': '高级装备需要稀有材料，多去危险区域探索吧。'
    }
  }
};

function handleNpcDialogCommand(ws, player, command) {
  const arg = command.replace('/对话', '').trim();
  if (!arg) {
    const npcs = Object.keys(NPC_DIALOGS);
    sendToClient(ws, { type: 'system', data: { message: `可对话NPC: ${npcs.join(', ')}\n用法: /对话 <NPC名> [话题]` } });
    return;
  }
  
  const parts = arg.split(/\s+/);
  const npcName = parts[0];
  const topic = parts.slice(1).join(' ');
  
  const npc = NPC_DIALOGS[npcName];
  if (!npc) { sendToClient(ws, { type: 'system', data: { message: `找不到NPC: ${npcName}` } }); return; }
  
  let content = `\n╔══════════════════════════════════╗\n║  对话: ${npcName}\n╠══════════════════════════════════╣\n║  "${npc.greeting}"\n║\n`;
  
  if (topic && npc.topics[topic]) {
    content += `║  【${topic}】\n║  "${npc.topics[topic]}"\n║\n`;
  }
  
  content += `║  可聊话题: ${Object.keys(npc.topics).join(', ')}\n╚══════════════════════════════════╝`;
  sendToClient(ws, { type: 'command_response', data: { title: `对话: ${npcName}`, content } });
}

// ===== RANDOM EVENT SYSTEM (随机事件) =====
const RANDOM_EVENTS = [
  { name: '神秘商人', desc: '遇到神秘商人，可以用低价购买稀有物品', effect: p => { p.silver = (p.silver || 0) + 50; return '获得50灵石'; } },
  { name: '灵气爆发', desc: '突然灵气爆发，修炼速度大增', effect: p => { p.exp = (p.exp || 0) + 100; return '获得100经验'; } },
  { name: '道心考验', desc: '面临道心考验', effect: p => { p.daoHeart = Math.min(1000, (p.daoHeart || 500) + 10); return '道心+10'; } },
  { name: '天降奇缘', desc: '天降奇缘，获得稀有材料', effect: p => { if (!p.materials) p.materials = {}; p.materials['天降奇缘'] = (p.materials['天降奇缘'] || 0) + 1; return '获得天降奇缘材料'; } },
  { name: '走火入魔', desc: '修炼走火入魔', effect: p => { p.hp = Math.max(1, (p.hp || 100) - 50); return 'HP-50'; } },
];

function handleRandomEventCommand(ws, player) {
  const event = RANDOM_EVENTS[Math.floor(Math.random() * RANDOM_EVENTS.length)];
  const players = getPlayers();
  const p = players[player.id];
  const result = event.effect(p);
  savePlayers(players);
  sendToClient(ws, { type: 'system', data: { message: `🎲 随机事件: ${event.name}\n${event.desc}\n结果: ${result}` } });
}

// ===== SECURITY (安全加固) =====
function sanitizeInput(input) {
  if (typeof input !== 'string') return '';
  return input.replace(/[<>"'&]/g, '').substring(0, 200);
}

// ===== LOGGING SYSTEM (日志系统) =====
const LOG_FILE = path.join(DATA_DIR, 'game.log');
function gameLog(type, message) {
  const timestamp = new Date().toISOString();
  const logEntry = `[${timestamp}] [${type}] ${message}\n`;
  try { fs.appendFileSync(LOG_FILE, logEntry); } catch(e) {}
}

// ===== AUTO SAVE & BACKUP (数据备份) =====
function autoBackup() {
  const backupDir = path.join(DATA_DIR, 'backups');
  if (!fs.existsSync(backupDir)) fs.mkdirSync(backupDir, { recursive: true });
  const timestamp = new Date().toISOString().replace(/[:.]/g, '-');
  try {
    const players = readJSON(PLAYERS_FILE);
    fs.writeFileSync(path.join(backupDir, `players_${timestamp}.json`), JSON.stringify(players, null, 2));
    // Keep only last 10 backups
    const files = fs.readdirSync(backupDir).filter(f => f.startsWith('players_')).sort();
    while (files.length > 10) {
      fs.unlinkSync(path.join(backupDir, files.shift()));
    }
  } catch(e) {}
}

// Auto backup every hour
setInterval(autoBackup, 3600000);

server.listen(PORT, () => {
  console.log(`赛博修仙服务器已启动，端口: ${PORT}`);
  console.log(`访问 http://localhost:${PORT} 开始游戏`);
});

module.exports = { app, server, wss };
