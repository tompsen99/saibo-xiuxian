  { level: 8, exp: 3600, abilities: '核心权限解锁, 暴击+15%' },
  { level: 9, exp: 4500, abilities: '创世者权限, 全属性+20%, 解锁真结局' }
];

function calcWatchLevel(watchExp) {
  for (let i = WATCH_EXP.length - 1; i >= 0; i--) {
    if (watchExp >= WATCH_EXP[i]) return i;
  }
  return 0;
}

