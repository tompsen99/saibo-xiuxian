</head>
<body>
  <div class="topbar">
    <h1>🎮 赛博修仙 · 管理员后台</h1>
    <div class="token-input">
      <span>Token:</span>
      <input type="password" id="tokenInput" value="admin123" placeholder="Admin Token">
      <span id="authStatus" class="status ok">已连接</span>
