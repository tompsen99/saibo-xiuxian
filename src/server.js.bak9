// ===== RELIC SET BONUS SYSTEM (遗物组合效果) =====
// Set bonus: 3件+5%, 6件+15%, 9件+30%, 12件解锁专属技能
const RELIC_SET_SKILLS = {
  month: { name: '岁月长河', desc: '十二月遗物集齐：全属性+50%，每回合回复10%HP' },
  hour: { name: '时间之轮', desc: '十二时辰遗物集齐：经验+50%，挂机经验翻倍' },
  zodiac: { name: '生肖轮回', desc: '十二生肖遗物集齐：暴击+50%，掉落翻倍' }
};

function getRelicSetBonus(player) {
  const types = { month: 0, hour: 0, zodiac: 0 };
  const relics = player.relics || [];
  for (const relicId of relics) {
    const r = RELICS_DATA[relicId];
    if (r && r.type && types[r.type] !== undefined) types[r.type]++;
  }
  let bonus = {};
  for (const [type, count] of Object.entries(types)) {
    if (count >= 12) bonus[type] = { pct: 50, skill: true };
    else if (count >= 9) bonus[type] = { pct: 30 };
    else if (count >= 6) bonus[type] = { pct: 15 };
    else if (count >= 3) bonus[type] = { pct: 5 };
  }
  return bonus;
}

// Admin Watch level thresholds (Lv0-Lv9, exp-based)
const WATCH_EXP = [0, 100, 300, 600, 1000, 1500, 2100, 2800, 3600, 4500];
